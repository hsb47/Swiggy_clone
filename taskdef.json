{
  "family": "swiggy",
  "networkMode": "awsvpc",
  "containerDefinitions": [
    {
      "name": "swiggy",
      "image": "hsb47/swiggy:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "hostPort": 3000,
          "protocol": "tcp"
        }
      ]
    }
  ],
  "requiresCompatibilities": [
    "EC2"
  ],
  "cpu": "256",
  "memory": "512"
}